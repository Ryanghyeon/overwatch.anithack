# OS 상관없이 줄바꿈 강제 통일 (Win-Mac 호환성)
* text=auto eol=lf

# GitHub PR(Pull Request)에서 lock 파일 소음 제거 (자동 접기)
package-lock.json linguist-generated=true
yarn.lock linguist-generated=true
pnpm-lock.yaml linguist-generated=true

# 이미지 및 폰트 파일 깨짐 방지 (바이너리로 인식)
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.webp binary
*.woff binary
*.woff2 binary

# SVG는 텍스트 기반 벡터이므로 줄바꿈 규칙 적용
*.svg text eol=lf